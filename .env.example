# WatchMyAI v1.0.0 setup template. The setup command generates the private .env file.
WATCHMYAI_MACHINE_ROLE=repository-only
WATCHMYAI_POLICY_MODE=signed
WATCHMYAI_HOME=/var/lib/watchmyai
ELASTICSEARCH_URL=https://elasticsearch.example.invalid:9200
KIBANA_URL=https://kibana.example.invalid:5601
KIBANA_SPACE=default
FLEET_SERVER_URL=https://fleet.example.invalid:8220
FLEET_AGENT_POLICY_ID=__SET_ME__
ELASTIC_AUTH_METHOD=api_key
ELASTIC_API_KEY=__SET_ME__
ELASTIC_API_KEY_FILE=
ELASTIC_USERNAME=
ELASTIC_PASSWORD=
TLS_VERIFY=true
ELASTIC_CA_CERT=__SET_ME__
FLEET_CA_CERT=__SET_ME__
CLAUDE_SETTINGS_PATH=
ELASTIC_AGENT_PATH=__SET_ME__
WATCHMYAI_DATASET=watchmyai.events
SOURCE_DATA_STREAM=logs-watchmyai.events-*
ALERT_INDEX_PATTERN=.alerts-security.alerts-*
VALIDATION_TIMEOUT_SECONDS=300
POLL_INTERVAL_SECONDS=5
WATCHMYAI_TEST_WORKSPACE=runtime/lab-workspace
WATCHMYAI_LAB_MODE=false
ENABLE_RULES=false
